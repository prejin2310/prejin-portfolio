rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public portfolio data — anyone can read
    match /{collection}/{document=**} {
      allow read: if true;
    }
    // Admin writes — only authenticated users
    match /{collection}/{document=**} {
      allow write: if request.auth != null;
    }
  }
}
